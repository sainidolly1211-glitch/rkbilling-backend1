# ============================================================
# RK GARMENTS BACKEND - Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Storage buckets
SUPABASE_BUCKET_PRODUCTS=product-images
SUPABASE_BUCKET_INVOICES=invoices
SUPABASE_BUCKET_LOGOS=logos
SUPABASE_BUCKET_BACKUPS=backups

# Security
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Business
HIGH_VALUE_SALE_THRESHOLD=5000
